#cách sử dụng middleware trong API
// 1. Import middleware cần thiết
import { protect, hasPermission, restrictTo, checkRoleAndPermission } from "../middlewares/auth.mdw.js";

// 2. Áp dụng vào routes:

// Yêu cầu đăng nhập
router.get("/projects", protect, getAllProjects);

// Yêu cầu quyền cụ thể
router.post("/projects", protect, hasPermission("create_project"), createProject);

// Yêu cầu vai trò nhất định
router.delete("/projects/:id", protect, restrictTo("Leader"), deleteProject);

// Yêu cầu cả vai trò và quyền cụ thể
router.put("/projects/:id", protect, checkRoleAndPermission(["Leader"], "update_project"), updateProject);

# Các mã quyền đề xuất
// Project permissions
"create_project", "view_project", "update_project", "delete_project"

// Task permissions
"create_task", "view_task", "update_task", "delete_task"

// Comment permissions
"create_comment", "update_comment", "delete_comment"

// Settings permissions
"manage_settings", "view_settings"

// TimeLog permissions
"manage_timelogs", "view_timelogs"

// Performance permissions
"view_performance"